# OPENAI_API_KEY=sk-...          # for OpenAI chat + embeddings
# GEMINI_API_KEY=...             # for Google Gemini (optional)
PINECONE_API_KEY=
HF_TOKEN=

# LLM Config (supported: ollama, gemini)
LLM_PROVIDER=ollama
OLLAMA_MODEL=glm-5.1:cloud
OLLAMA_BASE_URL=http://localhost:11434

